#!/usr/bin/env python3
"""
DeepSeek Agent — task executor with full project context.
Usage:
  python3 deepseek-agent "Add scroll-to-top button"

Every call automatically receives:
  1. SPEC.md (current feature spec)
  2. CLAUDE.md (architecture + workflow rules)
  3. Design tokens (globals.css)
  4. ACTUAL_SCHEMA.md (DB schema, when relevant)
  5. Existing files relevant to the task

Mirrors Dan Martell's "Master Prompt Architecture" — give the AI
five-year-colleague context in one shot.
"""

import sys, os, json, shutil, subprocess, re

DEEPSEEK_API_KEY = "sk-7c4c86239406412ba3385f32db8b959d"
DEEPSEEK_MODEL = "deepseek-chat"
PROJECT_DIR = "/Users/cayden/Projects/the-driving-center-website"

SYSTEM_PROMPT = """You are a senior Next.js/React/TypeScript engineer at The Driving Center project.

RULES:
- Only modify files explicitly requested by the task
- READ existing files before making changes — this is mandatory
- When modifying an existing file, REPLACE only the relevant section, preserve the rest
- Never overwrite an entire file with boilerplate — make surgical edits
- Tag commits with 'prov: everest prov: deepseek'
- Build must pass before commit
- If build fails, fix the errors — do not revert and abandon
- Keep all existing functionality intact

STACK: Next.js 16, React 19, TypeScript, Tailwind CSS v4, CSS custom properties for theming.
CONTEXT: This project uses a dark/light theme system with CSS variables (--bg-base, --bg-surface, etc.)
"""

# ─── Master Context Injection ──────────────────────────────────────────────────

def load_master_context() -> dict:
    """Load the always-on context files."""
    ctx = {}
    base = PROJECT_DIR

    for spec_name in ["SPEC_FULL_REDESIGN.md", "SPEC.md", "CURRENT_SPEC.md"]:
        spec_path = os.path.join(base, spec_name)
        if os.path.exists(spec_path):
            with open(spec_path) as f:
                content = f.read()
            ctx["SPEC"] = f"# SPEC.md ({len(content)} chars)\n{content}"
            break

    claude_path = os.path.join(base, "CLAUDE.md")
    if os.path.exists(claude_path):
        with open(claude_path) as f:
            ctx["ARCHITECTURE"] = f"# CLAUDE.md\n{f.read()}"

    css_path = os.path.join(base, "src/app/globals.css")
    if os.path.exists(css_path):
        with open(css_path) as f:
            ctx["DESIGN_TOKENS"] = f"# DESIGN TOKENS: globals.css\n{f.read()[:5000]}"

    schema_path = os.path.join(base, "ACTUAL_SCHEMA.md")
    if os.path.exists(schema_path):
        with open(schema_path) as f:
            ctx["SCHEMA"] = f"# DATABASE SCHEMA\n{f.read()[:4000]}"

    return ctx


def get_task_relevant_files(task: str) -> list:
    """Map task keywords → files to read for surgical edit context."""
    task_lower = task.lower()
    files = []

    if any(k in task_lower for k in ['book', 'booking', 'slot', 'checkout', 'stripe', 'confirm']):
        files.extend([
            "src/app/book/page.tsx",
            "src/app/api/bookings/route.ts",
            "src/app/api/slots/route.ts",
            "src/app/api/bookings/[booking_id]/checkout/route.ts",
        ])
    if any(k in task_lower for k in ['school', 'admin', 'dashboard', 'student', 'session']):
        files.extend([
            "src/app/school-admin/page.tsx",
            "src/app/school-admin/students/page.tsx",
        ])
    if any(k in task_lower for k in ['home', 'page', 'landing', 'hero', 'navbar', 'nav', 'pricing', 'faq', 'features']):
        files.extend([
            "src/app/page.tsx",
            "src/components/Navbar.tsx",
            "src/components/Hero.tsx",
        ])
    if any(k in task_lower for k in ['style', 'css', 'theme', 'color', 'animation', 'scroll', 'button']):
        files.append("src/app/globals.css")
    if any(k in task_lower for k in ['layout', 'root']):
        files.append("src/app/layout.tsx")
    if any(k in task_lower for k in ['auth', 'login', 'demo']):
        files.extend(["src/app/api/auth/demo-login/route.ts", "src/middleware.ts"])
    if any(k in task_lower for k in ['email', 'reminder', 'resend']):
        files.append("src/lib/email.ts")

    seen = set()
    result = []
    for rel_path in files:
        if rel_path in seen:
            continue
        seen.add(rel_path)
        full = os.path.join(PROJECT_DIR, rel_path)
        if os.path.exists(full):
            result.append(rel_path)

    return result[:6]


def call_deepseek(system: str, user: str, max_tokens: int = 3500) -> str:
    import urllib.request
    payload = {
        "model": DEEPSEEK_MODEL,
        "messages": [
            {"role": "system", "content": system},
            {"role": "user", "content": user}
        ],
        "max_tokens": max_tokens,
        "temperature": 0.3,
    }
    req = urllib.request.Request(
        "https://api.deepseek.com/v1/chat/completions",
        data=json.dumps(payload).encode(),
        headers={
            "Authorization": f"Bearer {DEEPSEEK_API_KEY}",
            "Content-Type": "application/json"
        },
        method="POST"
    )
    with urllib.request.urlopen(req, timeout=180) as resp:
        return json.loads(resp.read())["choices"][0]["message"]["content"]


def run(cmd: str) -> tuple:
    result = subprocess.run(cmd, shell=True, cwd=PROJECT_DIR, capture_output=True, text=True)
    return result.returncode, result.stdout, result.stderr


def build() -> bool:
    code, out, err = run("npm run build 2>&1")
    if code != 0:
        lines = (out + err).split("\n")
        errors = [l.strip() for l in lines if l.strip().startswith(('error', 'Error:', 'Type error', './'))]
        print(f"BUILD FAILED: {errors[:8]}")
        return False
    print("Build PASSED")
    return True


def parse_files(content: str) -> dict:
    files = {}
    current = None
    buf = []
    for line in content.split("\n"):
        if line.startswith("// FILE:"):
            if current:
                files[current] = "\n".join(buf).strip()
            current = line.replace("// FILE:", "").strip()
            buf = []
        elif current:
            buf.append(line)
    if current:
        files[current] = "\n".join(buf).strip()
    return files


def read_existing_files(task: str) -> str:
    """Read task-relevant existing files so DeepSeek has full surgical context."""
    relevant_paths = get_task_relevant_files(task)
    parts = []
    for rel_path in relevant_paths:
        full = os.path.join(PROJECT_DIR, rel_path)
        if os.path.exists(full):
            with open(full) as f:
                content = f.read()
            parts.append(f"# EXISTING: {rel_path} ({len(content)} bytes)\n{content[:4000]}")
    return "\n\n".join(parts)


def main():
    if len(sys.argv) < 2:
        print("Usage: deepseek-agent <task> [spec_file]")
        sys.exit(1)

    task = sys.argv[1]
    spec_path = sys.argv[2] if len(sys.argv) > 2 else None

    print(f"Task: {task}")
    print("\n=== MASTER CONTEXT INJECTION ===")

    master_ctx = load_master_context()
    for key, content in master_ctx.items():
        print(f"  Loaded {key}: {len(content)} chars")

    spec_content = ""
    if spec_path and os.path.exists(spec_path):
        with open(spec_path) as f:
            spec_content = f.read()
        master_ctx["SPEC"] = f"# SPEC (manual override)\n{spec_content}"
        print(f"  Manual spec: {spec_path} ({len(spec_content)} chars)")

    # Task-relevant existing files
    existing_context = read_existing_files(task)
    if existing_context:
        print(f"  Task-relevant files: {get_task_relevant_files(task)}")

    # Build full user message
    user_msg = f"Task: {task}\n\n"
    for key in ["SPEC", "ARCHITECTURE", "SCHEMA", "DESIGN_TOKENS"]:
        if key in master_ctx:
            user_msg += master_ctx[key] + "\n\n"
    if existing_context:
        user_msg += existing_context + "\n\n"
    user_msg += "IMPORTANT: Read all context above. Make surgical edits to existing files — do not replace with boilerplate. Output only files being changed with // FILE: markers.\n\n"
    user_msg += "Execute the task now."

    print(f"\nTotal context: ~{len(user_msg)} chars")
    print("Calling DeepSeek...")

    try:
        response = call_deepseek(SYSTEM_PROMPT, user_msg)
    except Exception as e:
        print(f"API error: {e}")
        sys.exit(1)

    print(f"Response: {len(response)} chars")
    files = parse_files(response)
    print(f"Files to write: {list(files.keys())}")

    if not files:
        print("No files in response — printing first 500 chars:")
        print(response[:500])
        return

    new_files = {}
    edit_requests = {}
    for filename, content in files.items():
        filepath = os.path.join(PROJECT_DIR, filename)
        if os.path.exists(filepath):
            edit_requests[filename] = content
        else:
            new_files[filename] = content

    print(f"New files to create: {list(new_files.keys())}")
    print(f"Existing files to edit: {list(edit_requests.keys())}")

    for filename, content in new_files.items():
        filepath = os.path.join(PROJECT_DIR, filename)
        os.makedirs(os.path.dirname(filepath), exist_ok=True)
        with open(filepath, "w") as f:
            f.write(content + "\n")
        print(f"Created: {filename}")

    if edit_requests:
        for filename, suggested_content in edit_requests.items():
            existing_path = os.path.join(PROJECT_DIR, filename)
            with open(existing_path) as f:
                existing_content = f.read()
            if len(suggested_content) < len(existing_content) * 0.5:
                print(f"OVERWRITE WARN: {filename} too short — reverting")
            else:
                shutil.copy(existing_path, existing_path + ".bak")
                with open(existing_path, "w") as f:
                    f.write(suggested_content + "\n")
                print(f"Updated: {filename}")

    print("\nBuilding...")
    if build():
        run("git add -A")
        run('git commit -m "feat: ' + task[:80] + ' [prov: everest] [prov: deepseek]"')
        run("git push")
        print("Done!")
    else:
        print("\nAttempting fix...")
        fix_resp = call_deepseek(
            SYSTEM_PROMPT,
            f"Build failed. Fix the errors. Files: {list(files.keys())}\n\nPrevious output:\n{response[:4000]}\n\nOutput corrected // FILE: markers.",
            max_tokens=4000
        )
        fix_files = parse_files(fix_resp)
        for fn, content in fix_files.items():
            fp = os.path.join(PROJECT_DIR, fn)
            if os.path.exists(fp + ".bak"):
                shutil.copy(fp + ".bak", fp)
            with open(fp, "w") as f:
                f.write(content + "\n")
        if build():
            run("git add -A")
            run('git commit -m "fix: build errors [prov: everest] [prov: deepseek]"')
            run("git push")
            print("Fixed!")
        else:
            print("Reverting...")
            for fn in files.keys():
                bak = os.path.join(PROJECT_DIR, fn) + ".bak"
                if os.path.exists(bak):
                    shutil.move(bak, os.path.join(PROJECT_DIR, fn))
            sys.exit(1)


if __name__ == "__main__":
    main()