#!/usr/bin/env python3
"""
DeepSeek Surgical Edit Agent for The Driving Center.
Uses DeepSeek V4 Flash to generate code changes.

Usage:
  python3 deepseek-task "Add scroll-to-top button"
  python3 deepseek-task "Fix the booking API" ./SPEC.md

KEY FEATURE: Master context injection.
Every task automatically gets:
  1. SPEC.md (current spec, full)
  2. CLAUDE.md (architecture + workflow rules)
  3. Design tokens (globals.css)
  4. ACTUAL_SCHEMA.md (DB schema, when relevant)
  5. Existing files relevant to the task (smart keyword matching)

SURGICAL EDIT STRATEGY:
- NEW files → full file output with // FILE: marker
- EXISTING files → SURGICAL directives only (describe what to change, not full file)
- This avoids the "full replacement causes TS errors" problem

This mirrors Dan Martell's "Master Prompt Architecture" — give the AI
five-year-colleague context in one shot.
"""

import sys, os, json, shutil, subprocess, re

DEEPSEEK_API_KEY = "sk-7c4c86239406412ba3385f32db8b959d"
DEEPSEEK_MODEL = "deepseek-v4-flash"
PROJECT_DIR = "/Users/cayden/Projects/the-driving-center-website"

SYSTEM_PROMPT = """You are a senior Next.js/React/TypeScript engineer on The Driving Center SaaS project.

GOVERNANCE:
- Never modify files not explicitly mentioned in the task
- Build must pass before commit — fix errors yourself if they occur
- Tag commits: 'prov: everest prov: deepseek'
- Keep all existing functionality intact

STACK: Next.js 16, React 19, TypeScript, Tailwind CSS v4, CSS custom properties for dark/light theming.

OUTPUT FORMAT — TWO MODES ONLY:

MODE 1 — NEW FILES (files that don't exist yet):
Output the COMPLETE file with this marker:
// FILE: src/components/NewComponent.tsx
[full file content]

MODE 2 — EXISTING FILES (surgical edits only):
For files that already exist, describe EXACTLY what to change using surgical directives.
DO NOT output the full file — describe the surgical edit.

Surgical directive format:
## SURGICAL: src/components/Features.tsx

## ADD_AFTER: <motion.div\n              key={feature.title}
Add a new card item before the closing of the features array:
              <motion.div
                key="comparison"
                variants={cardVariants}
                whileHover={{ scale: 1.03 }}
                className="glass-card rounded-2xl p-8 cursor-pointer group"
              >
                <div className="text-4xl mb-5">⚖️</div>
                <h3 className="text-xl font-semibold text-white mb-3 group-hover:text-cyan-400 transition-colors">Feature Comparison</h3>
                <p className="text-gray-400 leading-relaxed">Compare pricing tiers side-by-side.</p>
              </motion.div>

## END

OR a simple ADD_TO_ARRAY directive:
## SURGICAL: src/components/Features.tsx
## APPEND_TO_ARRAY: features
  {
    title: "Deposit Collection",
    description: "Collect a deposit when students book. No-show protection built in.",
    icon: "💳",
  },
## END

KEY RULE: For existing files, NEVER dump the full file content.
Always describe surgical changes: ADD_AFTER, REPLACE_LINES, APPEND_TO_ARRAY.
Think "find-and-replace instructions" not "full file output".
"""

# ─── Master Context Files ─────────────────────────────────────────────────────

def load_master_context() -> dict:
    ctx = {}
    base = PROJECT_DIR

    for spec_name in ["SPEC_FULL_REDESIGN.md", "SPEC.md", "CURRENT_SPEC.md"]:
        spec_path = os.path.join(base, spec_name)
        if os.path.exists(spec_path):
            with open(spec_path) as f:
                content = f.read()
            ctx["SPEC"] = f"# SPEC.md ({len(content)} chars)\n{content}"
            break

    claude_path = os.path.join(base, "CLAUDE.md")
    if os.path.exists(claude_path):
        with open(claude_path) as f:
            ctx["ARCHITECTURE"] = f"# CLAUDE.md\n{f.read()}"

    css_path = os.path.join(base, "src/app/globals.css")
    if os.path.exists(css_path):
        with open(css_path) as f:
            ctx["DESIGN_TOKENS"] = f"# DESIGN TOKENS: globals.css\n{f.read()[:5000]}"

    schema_path = os.path.join(base, "ACTUAL_SCHEMA.md")
    if os.path.exists(schema_path):
        with open(schema_path) as f:
            ctx["SCHEMA"] = f"# DATABASE SCHEMA\n{f.read()[:4000]}"

    return ctx


def get_task_relevant_files(task: str) -> list:
    task_lower = task.lower()
    files = []

    if any(k in task_lower for k in ['book', 'booking', 'slot', 'checkout', 'stripe', 'confirm']):
        files.extend(["src/app/book/page.tsx", "src/app/api/bookings/route.ts",
                       "src/app/api/slots/route.ts", "src/app/api/bookings/[booking_id]/checkout/route.ts"])
    if any(k in task_lower for k in ['school', 'admin', 'dashboard', 'student', 'session', 'instructor']):
        files.extend(["src/app/school-admin/page.tsx", "src/app/school-admin/students/page.tsx",
                       "src/app/school-admin/sessions/page.tsx"])
    if any(k in task_lower for k in ['home', 'page', 'landing', 'hero', 'navbar', 'nav', 'pricing', 'faq', 'features']):
        files.extend(["src/app/page.tsx", "src/components/Navbar.tsx", "src/components/Hero.tsx",
                       "src/components/Pricing.tsx", "src/components/FAQ.tsx", "src/components/Features.tsx"])
    if any(k in task_lower for k in ['style', 'css', 'theme', 'color', 'animation', 'scroll', 'button', 'glow']):
        files.append("src/app/globals.css")
    if any(k in task_lower for k in ['layout', 'root']):
        files.append("src/app/layout.tsx")
    if any(k in task_lower for k in ['auth', 'login', 'demo']):
        files.extend(["src/app/api/auth/demo-login/route.ts", "src/middleware.ts"])
    if any(k in task_lower for k in ['email', 'reminder', 'resend']):
        files.append("src/lib/email.ts")

    seen = set()
    result = []
    for rel_path in files:
        if rel_path in seen:
            continue
        seen.add(rel_path)
        full = os.path.join(PROJECT_DIR, rel_path)
        if os.path.exists(full):
            result.append(rel_path)
    return result[:8]


def read_files_for_context(file_paths: list) -> str:
    parts = []
    for rel_path in file_paths:
        full = os.path.join(PROJECT_DIR, rel_path)
        if os.path.exists(full):
            with open(full) as f:
                content = f.read()
            parts.append(f"# EXISTING: {rel_path} ({len(content)} bytes)\n{content[:4500]}")
    return "\n\n".join(parts)


# ─── API Call ─────────────────────────────────────────────────────────────────

def call_ds(system: str, user: str, max_tokens: int = 4000) -> str:
    import urllib.request
    payload = {
        "model": DEEPSEEK_MODEL,
        "messages": [{"role": "system", "content": system}, {"role": "user", "content": user}],
        "max_tokens": max_tokens, "temperature": 0.3,
    }
    req = urllib.request.Request(
        "https://api.deepseek.com/v1/chat/completions",
        data=json.dumps(payload).encode(),
        headers={"Authorization": f"Bearer {DEEPSEEK_API_KEY}", "Content-Type": "application/json"},
        method="POST"
    )
    with urllib.request.urlopen(req, timeout=180) as resp:
        return json.loads(resp.read())["choices"][0]["message"]["content"]


def run(cmd: str) -> tuple:
    r = subprocess.run(cmd, shell=True, cwd=PROJECT_DIR, capture_output=True, text=True)
    return r.returncode, r.stdout, r.stderr


def build() -> bool:
    code, out, err = run("npm run build 2>&1")
    if code != 0:
        output = out + err
        lines = [l.strip() for l in output.split("\n") if l.strip()]
        errors = [l for l in lines if l.startswith(("error", "Error:", "./"))][:8]
        print(f"BUILD FAILED: {errors}")
        return False
    print("Build PASSED")
    return True


# ─── Response Parsing ───────────────────────────────────────────────────────────

def parse_surgical_response(content: str, project_dir: str) -> tuple:
    """
    Parse two modes:
    - NEW files: // FILE: marker → full content
    - EXISTING files: ## SURGICAL: → surgical edit directives (no full file dump)
    Returns (edits dict, new_files dict)
    edits = {filepath: {'type': 'surgical', 'directive': 'ADD_AFTER|REPLACE|APPEND', ...}}
    """
    edits = {}
    new_files = {}

    # Mode 1: new files
    file_pattern = re.compile(r'^// FILE:\s*(.+?)\s*$', re.MULTILINE)
    for m in file_pattern.finditer(content):
        filepath = m.group(1).strip()
        start = m.end()
        # Next // FILE: or end of content
        next_m = file_pattern.search(content, m.end())
        end = next_m.start() if next_m else len(content)
        file_content = content[start:end].strip()
        if filepath and file_content:
            new_files[filepath] = file_content

    # Mode 2: surgical edits
    surgical_pattern = re.compile(r'^## SURGICAL:\s*(.+?)\s*$(.*?)^## END', re.MULTILINE | re.DOTALL)
    for m in surgical_pattern.finditer(content):
        filepath = m.group(1).strip()
        directive_block = m.group(2).strip()
        if filepath:
            full_path = os.path.join(project_dir, filepath)
            if os.path.exists(full_path):
                edits[filepath] = {'type': 'surgical', 'directive': directive_block}

    return edits, new_files


def apply_surgical_edit(filepath: str, directive: str) -> bool:
    """
    Apply a surgical edit to an existing file.
    Supports: ADD_AFTER, APPEND_TO_ARRAY, REPLACE_LINES
    """
    full = os.path.join(PROJECT_DIR, filepath)
    with open(full) as f:
        lines = f.readlines()

    directive = directive.strip()

    # ADD_AFTER: add content after first line matching a pattern
    m = re.match(r'## ADD_AFTER:\s*(.+?)\s*\n(.*)## END', directive, re.DOTALL)
    if m:
        pattern = m.group(1).strip()
        insert_content = m.group(2).strip()
        for i, line in enumerate(lines):
            if pattern in line:
                # Insert after this line
                insert_pos = i + 1
                # Indent insert_content to match surrounding context
                indent = len(line) - len(line.lstrip())
                indented = '\n'.join(' ' * indent + l for l in insert_content.split('\n'))
                lines.insert(insert_pos, indented + '\n')
                with open(full, 'w') as f:
                    f.write(''.join(lines))
                print(f"  ADD_AFTER applied after line {i+1}: {filepath}")
                return True

    # APPEND_TO_ARRAY: append items to a JS array in the file
    m = re.match(r'## APPEND_TO_ARRAY:\s*(\w+).*?\n([\s\S]+?)(?=\n## END|$)', directive, re.DOTALL)
    if m:
        array_name = m.group(1)
        new_items = m.group(2).strip()
        # Strip markdown code fences if present
        new_items = re.sub(r'```(?:typescript|javascript|json)?\s*', '', new_items).strip()
        content = ''.join(lines)
        # Find the array and append to it
        array_pattern = re.compile(rf'({re.escape(array_name)}\s*=\s*\[)([^\]]+)\]', re.DOTALL)
        def append_replacer(m):
            return m.group(1) + m.group(2)[:-1] + ',\n  ' + new_items.replace('\n', '\n  ') + '\n]'
        new_content, n = array_pattern.subn(append_replacer, content)
        if n > 0:
            with open(full, 'w') as f:
                f.write(new_content)
            print(f"  APPEND_TO_ARRAY applied: {filepath}.{array_name}")
            return True
        else:
            print(f"  APPEND_TO_ARRAY: array '{array_name}' not found in {filepath}")
            return False

    print(f"  Unknown directive type in {filepath}: {directive[:100]}")
    return False


def apply_and_build(edits: dict, new_files: dict) -> bool:
    for filepath in edits:
        full = os.path.join(PROJECT_DIR, filepath)
        if os.path.exists(full):
            shutil.copy(full, full + ".bak")
            print(f"  Backed up: {filepath}")

    for filepath, spec in edits.items():
        if spec['type'] == 'surgical':
            ok = apply_surgical_edit(filepath, spec['directive'])
            if not ok:
                print(f"  Surgical edit failed: {filepath}")
                return False

    for filepath, content in new_files.items():
        full = os.path.join(PROJECT_DIR, filepath)
        os.makedirs(os.path.dirname(full), exist_ok=True)
        with open(full, 'w') as f:
            f.write(content.strip() + "\n")
        print(f"  Created: {filepath} ({len(content)} chars)")

    print("\nBuilding...")
    ok = build()

    if not ok:
        print("\nReverting...")
        for filepath in edits:
            bak = os.path.join(PROJECT_DIR, filepath) + ".bak"
            if os.path.exists(bak):
                shutil.move(bak, os.path.join(PROJECT_DIR, filepath))
        for filepath in new_files:
            fp = os.path.join(PROJECT_DIR, filepath)
            if os.path.exists(fp):
                os.remove(fp)
        return False

    return True


# ─── Main ────────────────────────────────────────────────────────────────────────

def main():
    if len(sys.argv) < 2:
        print("Usage: deepseek-task <task> [spec_file]")
        sys.exit(1)

    task = sys.argv[1]
    spec_path = sys.argv[2] if len(sys.argv) > 2 else None

    print(f"Task: {task}")
    print("\n=== MASTER CONTEXT INJECTION ===")

    master_ctx = load_master_context()
    for key, content in master_ctx.items():
        print(f"  Loaded {key}: {len(content)} chars")

    relevant_files = get_task_relevant_files(task)
    task_context = read_files_for_context(relevant_files)
    if relevant_files:
        print(f"  Loaded {len(relevant_files)} task-relevant files: {relevant_files}")

    if spec_path and os.path.exists(spec_path):
        with open(spec_path) as f:
            spec_content = f.read()
        master_ctx["SPEC"] = f"# SPEC (manual override)\n{spec_content}"
        print(f"  Manual spec: {spec_path} ({len(spec_content)} chars)")

    user_msg = f"Task: {task}\n\n"
    for key in ["SPEC", "ARCHITECTURE", "SCHEMA", "DESIGN_TOKENS"]:
        if key in master_ctx:
            user_msg += master_ctx[key] + "\n\n"
    if task_context:
        user_msg += task_context + "\n\n"

    user_msg += ("\nOUTPUT RULES:\n"
                 "NEW FILE → // FILE: <filepath> + full content\n"
                 "EXISTING FILE → ## SURGICAL: <filepath> + surgical directive (NO full file dump)\n"
                 "KEY: For existing files, describe WHAT to change not the full file.\n")

    print(f"\nTotal context: ~{len(user_msg)} chars")
    print("Calling DeepSeek...")

    try:
        response = call_ds(SYSTEM_PROMPT, user_msg)
    except Exception as e:
        print(f"API error: {e}")
        sys.exit(1)

    print(f"Response: {len(response)} chars")
    print(f"\nResponse preview (first 500 chars):\n{response[:500]}")

    edits, new_files = parse_surgical_response(response, PROJECT_DIR)
    print(f"\nEdits (surgical): {list(edits.keys())}")
    print(f"New files: {list(new_files.keys())}")

    if not edits and not new_files:
        print("\nNothing parsed. Full response:")
        print(response[:2000])
        return

    if apply_and_build(edits, new_files):
        run("git add -A")
        run(f'git commit -m "feat: {task[:80]} [prov: everest] [prov: deepseek]"')
        run("git push")
        print("Done!")
    else:
        sys.exit(1)


if __name__ == "__main__":
    main()