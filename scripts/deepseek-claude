#!/usr/bin/env python3
"""
Spawns a Claude Code agent powered by DeepSeek V4 Flash.
Usage:
  python3 deepseek-claude "Build the login page"
  python3 deepseek-claude "Fix the auth bug" ./SPEC.md

Sets ANTHROPIC_BASE_URL + ANTHROPIC_AUTH_TOKEN to route Claude Code
through DeepSeek's Anthropic-compatible endpoint.
"""

import sys, os, subprocess

CLAUDE_BIN = "/opt/homebrew/bin/claude"
DEEPSEEK_KEY = "sk-7c4c86239406412ba3385f32db8b959d"
MODEL = "deepseek-chat"  # DeepSeek V4 Flash (chat completions compatible)

ENV = os.environ.copy()
ENV["ANTHROPIC_BASE_URL"] = "https://api.deepseek.com/anthropic"
ENV["ANTHROPIC_AUTH_TOKEN"] = DEEPSEEK_KEY
ENV["ANTHROPIC_MODEL"] = MODEL

def main():
    if len(sys.argv) < 2:
        print("Usage: deepseek-claude <task> [spec_file]")
        sys.exit(1)

    task = sys.argv[1]
    spec_path = sys.argv[2] if len(sys.argv) > 2 else None

    # Build the prompt
    prompt_parts = [task]
    if spec_path and os.path.exists(spec_path):
        spec_content = open(spec_path).read()
        prompt_parts.append(f"\n\nSPEC:\n{spec_content}")

    prompt = "\n".join(prompt_parts)

    # Build the claude command
    cmd = [
        CLAUDE_BIN,
        "--permission-mode", "bypassPermissions",
        "--print",
        prompt
    ]

    print(f"Running Claude Code on DeepSeek ({MODEL}) in: /Users/cayden/Projects/the-driving-center-website")

    result = subprocess.run(
        cmd,
        cwd="/Users/cayden/Projects/the-driving-center-website",
        env=ENV,
        timeout=300,
    )

    sys.exit(result.returncode)

if __name__ == "__main__":
    main()